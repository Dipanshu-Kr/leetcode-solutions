class Solution {
    public int findKthLargest(int[] nums, int k) {
        Arrays.sort(nums);
        int count = 1;
        int temp = 0;
        for(int i = nums.length - 1; i >= 0; i--){
            if(count == k){
                temp = nums[i];
                break;
            }
            count++;
        }
        return temp;
    }
}
