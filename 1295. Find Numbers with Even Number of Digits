class Solution {
    public int findNumbers(int[] nums) {
        int even_Digits = 0;
        for(int i = 0; i < nums.length; i++){
            int digits = 0;
            int temp = nums[i];
            while(temp > 0){
                temp /= 10;
                digits++;
            }
            if(digits % 2 == 0){
                even_Digits++;
            }
        }
        return even_Digits;
    }
}
