class Solution {
    public List<Integer> findWordsContaining(String[] words, char x) {
        List<Integer> temp = new ArrayList<>();
        for(int i = 0; i < words.length; i++){
            String len = words[i];
            for(int j = 0; j < len.length(); j++){
                if(len.charAt(j) == x){
                    temp.add(i);
                    break;
                }
            }
        }
        return temp;
    }
}
