class Solution {
    public int findNonMinOrMax(int[] nums) {
        if(nums.length <= 2){
            return -1;
        }
        int min = nums[0];
        int max = nums[0];
        for(int i = 0; i < nums.length; i++){
            min = Math.min(min, nums[i]);
            max = Math.max(max, nums[i]);
        }
        for(int i = 0; i < nums.length; i++){
            if(nums[i] != min && nums[i] != max){
                return nums[i];
            }
        }
        return -1;


    }
}
