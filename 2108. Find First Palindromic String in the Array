class Solution {
    public String firstPalindrome(String[] words) {
        String str = "";
        
        for(int i = 0; i < words.length; i++){
            int s = 0;
            int e = words[i].length() - 1;
            Boolean isPalindrome = true;
            while(s <= e){
                if(words[i].charAt(s) != words[i].charAt(e)){
                   isPalindrome = false;
                   break;
                }
                s++;
                e--;
            }
            if(isPalindrome){
                return words[i];
            }
        }
        return str;
       
    }
}
