class Solution {
    public String reverseWords(String s) {
        s = s.trim().replaceAll("\\s+", " ");
        String arr[] = s.split(" ");
        String temp ="";
        for(int i = arr.length - 1; i > 0 ; i--){
            temp = temp + arr[i] + ' ';
        }
        return temp + arr[0];
    }
}
