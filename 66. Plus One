class Solution {
    public int[] plusOne(int[] digits) {
        int [] arr = new int[digits.length + 1];
        arr [0] = 1;
        for(int i = digits.length - 1; i >= 0; i--){
            if(digits[i] < 9){
                digits[i] = digits[i] + 1;
                return digits;
            }else{
               digits[i] = 0;
               arr[i + 1] = 0; 
            }
            
        }
        return arr;
    }
}
