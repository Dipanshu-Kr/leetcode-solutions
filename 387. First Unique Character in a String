class Solution {
    public int firstUniqChar(String s) {
        for(int i = 0; i<s.length(); i++){
            int a = 0;
            for(int j = 0; j<s.length(); j++){
                if(s.charAt(i)==s.charAt(j) && i!=j){
                    a++;
                    break;
                }
            }

            if(a==0){
                return i;
            }
        }

        return -1;
    }
}
