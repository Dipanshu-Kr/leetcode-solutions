import java.util.Arrays;
class Solution {
    public int majorityElement(int[] nums) {
        Arrays.sort(nums);
        int max = 0;
        int curr = 0;
        int n = nums[0];
        for(int i = 0; i < nums.length - 1; i++){
            if(nums[i] == nums[i + 1]){
                curr++;
            }
            else{
                curr = 1;
            }
            if(curr > max){
                max = Math.max(curr, max);
                n = nums[i];

            }
        }
        return n;
    }
}
