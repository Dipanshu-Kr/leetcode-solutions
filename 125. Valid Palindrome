class Solution {
    public boolean isPalindrome(String s) {
        if (s.isEmpty()) {
        	return true;
        }
        String letter = s.replaceAll("[^a-zA-Z0-9]", "");
        String lower = letter.toLowerCase();
        int i = 0;
        for(int j = lower.length() - 1; j >= 0; j--){
            if(lower.charAt(i++) != lower.charAt(j)){
                return false;
            }
        }
        return true;
    }
}
