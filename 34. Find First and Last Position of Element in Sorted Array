class Solution {
    public static int firstOccurence(int[] nums, int target){
        int s = 0; 
        int e = nums.length - 1;
        int ans = -1;

        while(s <= e){
            int mid = (s + e) / 2;

            if(nums[mid] == target){
                ans = mid;
                e = mid - 1; 
            } 
            else if(nums[mid] < target){
                s = mid + 1;
            } 
            else {
                e = mid - 1;
            }
        }
        return ans;
    }

    public static int lastOccurence(int[] nums, int target){
        int s = 0; 
        int e = nums.length - 1;
        int ans = -1;

        while(s <= e){
            int mid = (s + e) / 2;

            if(nums[mid] == target){
                ans = mid;
                s = mid + 1; 
            } 
            else if(nums[mid] < target){
                s = mid + 1;
            } 
            else {
                e = mid - 1;
            }
        }
        return ans;
    }

    public int[] searchRange(int[] nums, int target) {
        return new int[]{
            firstOccurence(nums, target),
            lastOccurence(nums, target)
        };
    }
}
